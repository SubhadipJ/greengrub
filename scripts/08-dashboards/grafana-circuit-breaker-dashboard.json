{
  "title": "GreenGrub Circuit Breakers",
  "uid": "greengrub-cb",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Circuit Breaker State",
      "description": "CLOSED = healthy  |  OPEN = tripping  |  HALF_OPEN = recovering",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "minVizWidth": 150
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 2,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "CLOSED",    "color": "green"  },
                "1": { "text": "OPEN",      "color": "red"    },
                "2": { "text": "HALF_OPEN", "color": "yellow" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "red",    "value": 1    },
              { "color": "yellow", "value": 2    }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (name, app) (resilience4j_circuitbreaker_state * on(name,app) group_left() (resilience4j_circuitbreaker_state == 1))",
          "legendFormat": "{{app}} / {{name}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Failure Rate % (opens circuit at 50%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "minVizWidth": 120
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30   },
              { "color": "red",    "value": 50   }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "resilience4j_circuitbreaker_failure_rate{failure_rate!=\"-1.0\"}",
          "legendFormat": "{{app}} / {{name}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Slow Call Rate %",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "minVizWidth": 120
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30   },
              { "color": "red",    "value": 50   }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "resilience4j_circuitbreaker_slow_call_rate{slow_call_rate!=\"-1.0\"}",
          "legendFormat": "{{app}} / {{name}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Successful Calls / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(resilience4j_circuitbreaker_calls_seconds_count{kind=\"successful\"}[1m])",
          "legendFormat": "{{app}} / {{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Failed Calls / sec",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(resilience4j_circuitbreaker_calls_seconds_count{kind=\"failed\"}[1m])",
          "legendFormat": "{{app}} / {{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Blocked Calls / sec (circuit OPEN)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(resilience4j_circuitbreaker_not_permitted_calls_total[1m])",
          "legendFormat": "{{app}} / {{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Call Duration p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(resilience4j_circuitbreaker_calls_seconds_bucket{kind=\"successful\"}[5m])) * 1000",
          "legendFormat": "{{app}} / {{name}} p99",
          "refId": "A"
        }
      ]
    }
  ]
}
