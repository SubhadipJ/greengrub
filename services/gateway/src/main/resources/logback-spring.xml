<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Standard Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Local Profile Layout -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

    <!-- Non-Local Profiles Layout (e.g., prod) -->
    <springProfile name="!local">
        <!-- If you have a Logstash appender block, it must be defined and placed inside here -->
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

</configuration>
