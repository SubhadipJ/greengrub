pipeline {
    agent any

    environment {
        SERVICE_NAME          = 'greengrub-notification-service'
        DOCKER_HUB_USER       = 'subhadipj'
        DOCKER_CREDENTIALS_ID = 'docker_cred'
        K8S_CREDENTIALS_ID    = 'k8s-cluster-config'
        K8S_API_SERVER        = 'https://10.160.0.3:6443'
        SONAR_SERVER_NAME     = 'SonarQube'
    }

    tools {
        maven 'maven_3_9'
        jdk   'JDK17'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            when {
                anyOf {
                    changeset "services/notification/**"
                    expression { currentBuild.previousBuild == null }
                    triggeredBy 'UserIdCause'
                }
            }
            steps {
                dir('services/notification') {
                    sh 'mvn clean compile -DskipTests'
                }
            }
        }

        stage('Test') {
            when {
                anyOf {
                    changeset "services/notification/**"
                    expression { currentBuild.previousBuild == null }
                    triggeredBy 'UserIdCause'
                }
            }
            steps {
                dir('services/notification') {
                    sh 'mvn test -Dspring.profiles.active=local'
                }
            }
        }

        stage('SonarQube Quality Scan') {
            when {
                anyOf {
                    changeset "services/notification/**"
                    expression { currentBuild.previousBuild == null }
                    triggeredBy 'UserIdCause'
                }
            }
            steps {
                dir('services/notification') {
                    withSonarQubeEnv("${SONAR_SERVER_NAME}") {
                        sh """
                            mvn clean verify sonar:sonar \
                            -Dspring.profiles.active=local \
                            -Dsonar.projectKey=greengrub-notification-service \
                            -Dsonar.projectName="GreenGrub - Notification Service" \
                            -Dsonar.host.url=http://172.17.0.1:9000 \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            when {
                anyOf {
                    changeset "services/notification/**"
                    expression { currentBuild.previousBuild == null }
                    triggeredBy 'UserIdCause'
                }
            }
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Check Test Coverage') {
            when {
                anyOf {
                    changeset "services/notification/**"
                    expression { currentBuild.previousBuild == null }
                    triggeredBy 'UserIdCause'
                }
            }
            steps {
                dir('services/notification') {
                    script {
                        def coverage = sh(
                            script: "grep -oP 'Total.*?\\K\\d+(?=%)' target/site/jacoco/index.html | tail -1 || echo '0'",
                            returnStdout: true
                        ).trim()
                        echo "Test Coverage: ${coverage}%"
                        if (coverage.toInteger() < 80) {
                            error("Test coverage is ${coverage}%. Minimum required is 80%. Pipeline terminated.")
                        } else {
                            echo "Test coverage (${coverage}%) is above 80%. Proceeding..."
                        }
                    }
                }
            }
        }

        stage('Build & Tag Docker Image') {
            when {
                anyOf {
                    changeset "services/notification/**"
                    expression { currentBuild.previousBuild == null }
                    triggeredBy 'UserIdCause'
                }
            }
            steps {
                dir('services/notification') {
                    sh "docker build -t ${DOCKER_HUB_USER}/${SERVICE_NAME}:${BUILD_NUMBER} ."
                }
            }
        }

        stage('Push to Docker Hub') {
            when {
                anyOf {
                    changeset "services/notification/**"
                    expression { currentBuild.previousBuild == null }
                    triggeredBy 'UserIdCause'
                }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDENTIALS_ID}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"
                    sh "docker push ${DOCKER_HUB_USER}/${SERVICE_NAME}:${BUILD_NUMBER}"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            when {
                anyOf {
                    changeset "services/notification/**"
                    expression { currentBuild.previousBuild == null }
                    triggeredBy 'UserIdCause'
                }
            }
            steps {
                dir('services/notification') {
                    withKubeConfig([credentialsId: "${K8S_CREDENTIALS_ID}", serverUrl: "${K8S_API_SERVER}"]) {
                        sh "sed -i 's|IMAGE_NAME|${DOCKER_HUB_USER}/${SERVICE_NAME}:${BUILD_NUMBER}|g' k8s.yaml"
                        sh "kubectl apply -f k8s.yaml -n services"
                        sh "kubectl rollout status deployment/notification-service -n services --timeout=90s"
                    }
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${DOCKER_HUB_USER}/${SERVICE_NAME}:${BUILD_NUMBER} || true"
            cleanWs()
        }
        success {
            echo 'Notification Service pipeline completed successfully.'
        }
        failure {
            echo 'Notification Service pipeline failed.'
        }
    }
}
