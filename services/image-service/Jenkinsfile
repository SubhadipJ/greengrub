pipeline {
    agent any

    environment {
        SERVICE_NAME          = 'greengrub-image-service'
        DOCKER_HUB_USER       = 'subhadipj'
        IMAGE_TAG             = "${BUILD_NUMBER}-${GIT_COMMIT.take(7)}"
        GITHUB_USERNAME       = 'SubhadipJ'
        GITHUB_TOKEN          = credentials('SJ_Git_Cred')
        DOCKER_CREDENTIALS_ID = 'docker_cred'
        K8S_CREDENTIALS_ID    = 'k8s-cluster-config'
        K8S_API_SERVER        = 'https://10.160.0.3:6443'
        SONAR_SERVER_NAME     = 'SonarQube'
    }

    tools {
        maven 'maven_3_9'
        jdk   'JDK17'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            when { changeset "services/image-service/**" }
            steps {
                dir('services/image-service') {
                    sh 'mvn clean compile -s settings.xml -DskipTests'
                }
            }
        }

        stage('Test') {
            when { changeset "services/image-service/**" }
            steps {
                dir('services/image-service') {
                    sh 'mvn test -s settings.xml'
                }
            }
        }

        stage('SonarQube Quality Scan') {
            when { changeset "services/image-service/**" }
            steps {
                dir('services/image-service') {
                    withSonarQubeEnv("${SONAR_SERVER_NAME}") {
                        sh """
                            mvn clean verify sonar:sonar -s settings.xml \
                            -Dsonar.projectKey=greengrub-image-service \
                            -Dsonar.projectName="GreenGrub - Image Service" \
                            -Dsonar.host.url=http://172.17.0.1:9000 \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            when { changeset "services/image-service/**" }
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Check Test Coverage') {
            when { changeset "services/image-service/**" }
            steps {
                dir('services/image-service') {
                    script {
                        def coverage = sh(
                            script: "grep -oP 'Total.*?\\K\\d+(?=%)' target/site/jacoco/index.html | tail -1 || echo '0'",
                            returnStdout: true
                        ).trim()

                        echo "Test Coverage: ${coverage}%"

                        if (coverage.toInteger() < 80) {
                            error("Test coverage is ${coverage}%. Minimum required is 80%. Pipeline terminated.")
                        } else {
                            echo "Test coverage (${coverage}%) is above 80%. Proceeding..."
                        }
                    }
                }
            }
        }

        stage('Build & Tag Docker Image') {
            when { changeset "services/image-service/**" }
            steps {
                dir('services/image-service') {
                    sh "docker build -t ${DOCKER_HUB_USER}/${SERVICE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Push to Docker Hub') {
            when { changeset "services/image-service/**" }
            steps {
                withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDENTIALS_ID}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"
                    sh "docker push ${DOCKER_HUB_USER}/${SERVICE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            when { changeset "services/image-service/**" }
            steps {
                dir('services/image-service') {
                    withKubeConfig([credentialsId: "${K8S_CREDENTIALS_ID}", serverUrl: "${K8S_API_SERVER}"]) {
                        sh "sed -i 's|IMAGE_NAME|${DOCKER_HUB_USER}/${SERVICE_NAME}:${IMAGE_TAG}|g' k8s.yaml"
                        sh "kubectl apply -f k8s.yaml -n services"
                        sh "kubectl rollout status deployment/image-service -n services --timeout=90s"
                    }
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${DOCKER_HUB_USER}/${SERVICE_NAME}:${IMAGE_TAG} || true"
            cleanWs()
        }
        success {
            echo 'Image Service pipeline completed successfully.'
        }
        failure {
            echo 'Image Service pipeline failed.'
        }
    }
}
